# artifacts
__pycache__
.pytest*
*.egg-info
*/build/*
*/dist/*
node_modules

# card build output (intermediate; deployed copy lives in www/)
custom_components/btoddb_ha_reminders/card/btoddb-ha-reminders.js
custom_components/btoddb_ha_reminders/card/btoddb-ha-reminders.js.map

# local stuff
devcontainer-lock.json
.devcontainer-lock.json

# misc
.coverage
.vscode
coverage.xml
.ruff_cache

# Home Assistant configuration
config/*
!config/configuration.yaml

# Home Assistant config backups (throwaway runtime state: .storage, db, logs, cache)
config.backup*/

# don't commit extra custom components used for testing
custom_components/*
!custom_components/btoddb_ha_reminders

# local dev symlink to the sibling BToddB Notifications repo (issue #72); never commit
# the symlink itself, only reference its service contract.
custom_components/btoddb_notifications