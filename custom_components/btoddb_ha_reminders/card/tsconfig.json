{
  "compilerOptions": {
    "target": "es2021",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["es2021", "dom", "dom.iterable"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "experimentalDecorators": false,
    "useDefineForClassFields": false
  },
  "include": ["src/**/*.ts"]
}
